# OpenBallot Nigeria - environment template
# Copy to .env.local (web) / .env (worker) and fill in.

# ── Web (Next.js) ────────────────────────────────────────────────────────────
# When NEXT_PUBLIC_SUPABASE_URL is unset, the web app falls back to
# deterministic mock data. This lets investors clone and run with no infra.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_WORKER_URL=http://localhost:8000
NEXT_PUBLIC_BUILD_SHA=dev

# ── Worker (FastAPI) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://openballot:openballot@localhost:5432/openballot
REDIS_URL=redis://localhost:6379/0

STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ec8a-evidence

# Extraction backends (left blank in dev to use the deterministic stub)
GOOGLE_DOCUMENT_AI_PROJECT=
GOOGLE_DOCUMENT_AI_PROCESSOR=
OPENAI_API_KEY=

# Blockchain anchoring
ETHEREUM_RPC_URL=
ETHEREUM_ANCHOR_ADDRESS=
ANCHOR_ENABLED=false

# Twilio (agent OTPs). When TWILIO_ENABLED is false (default) the worker
# uses a NoOp adapter that logs the OTP to stdout - never deploy with this
# disabled in production.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1...

# Agent JWT. MUST be a high-entropy random string in production
# (`openssl rand -hex 48`). The default is fine for dev only.
AGENT_JWT_SECRET=dev-only-change-me-in-prod-or-via-env
AGENT_JWT_TTL_SECONDS=86400

# Auth thresholds
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_PHONE_PER_10MIN=3
OTP_MAX_REQUESTS_PER_IP_PER_HOUR=30
